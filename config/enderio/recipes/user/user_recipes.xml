<?xml version="1.0" encoding="UTF-8"?>
<enderio:recipes xmlns:enderio="http://enderio.com/recipes" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://enderio.com/recipes recipes.xsd ">

  <!-- ============================================
       NEXUS ABSOLU - Custom EnderIO recipes
       Loaded natively by EnderIO so slot validation works
       (CT addRecipe via mods.enderio.AlloySmelter doesn't update
       EnderIO's slot validation cache - we use native XML instead)
       ============================================ -->

  <!-- NEXUS STEEL : Iron Insule + Coal Coke (oredict) -> Steel -->
  <!-- Iron Insule = 1 iron + 8 wall_dust crafte en table (recette dans Age1_EnderIO.zs) -->
  <!-- 2 inputs evite le conflit de slots EnderIO -->
  <!-- fuelCoke = oredict qui matche IE ET TF coal coke -->
  <recipe name="Nexus Steel" required="true">
    <alloying energy="5000" exp="0.5">
      <input name="nexusabsolu:iron_insule"/>
      <input name="oredict:fuelCoke"/>
      <output name="thermalfoundation:material:160"/>
    </alloying>
  </recipe>

  <!-- Disable default EnderIO steel recipes found in alloying_modded.pdf -->
  <!-- EXACT names extracted from EnderIO's embedded recipe dump: -->
  <recipe name="Alloy: Steel" disabled="true" />
  <recipe name="Alloy: Steel (Oredict)" disabled="true" />

</enderio:recipes>

